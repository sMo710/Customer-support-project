# Global ignore for monorepo

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.iml
*.iws
*.ipr

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env / secrets
.env
.env.*
!.env.example
**/*.env
**/*.pem
**/*.key
**/*credentials*.json
**/*secret*.txt

# Java / Maven
**/target/
**/.mvn/wrapper/maven-wrapper.jar

# Node / React
**/node_modules/
**/build/
**/coverage/

# Temporary files
*.tmp
*.swp
